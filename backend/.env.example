# Sao chép file này thành ".env" rồi điền thông tin project Supabase của bạn.
# Lấy 2 giá trị này ở: Supabase Dashboard → Project Settings → API

# Project URL, dạng: https://xxxxxxxx.supabase.co
SUPABASE_URL=

# service_role key (KHÔNG dùng anon/public key — service_role mới có quyền
# ghi dữ liệu và bỏ qua Row Level Security). Giữ key này bí mật, đừng commit
# lên Git hay để lộ ở frontend.
SUPABASE_SERVICE_ROLE_KEY=

# (tuỳ chọn) Cổng chạy backend, mặc định 3001
PORT=3001
